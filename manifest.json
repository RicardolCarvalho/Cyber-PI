{
  "manifest_version": 2,
  "name": "Cyber-PI",
  "version": "1.0.0",
  "description": "Privacy Inspector - Detecta rastreadores, cookies, fingerprinting e ameaças de segurança na navegação web.",
  "icons": {
    "48": "icons/icon-48.png"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "cookies",
    "storage",
    "tabs",
    "webNavigation",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["data/trackers.js", "background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "default_title": "Cyber-PI",
    "default_popup": "popup/popup.html"
  }
}
